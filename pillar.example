# -*- coding: utf-8 -*-
# vim: ft=yaml
---
# Example URIs come from navigating the official Mozilla (mirrors) for
# downloading arbitrary versions of the Firefox installer. As of this
# file's author/edit-date, older versions of the Firefox installers
# may be found by exploring the hierarchy rooted at:
#
#    https://download-installer.cdn.mozilla.net/pub/firefox/releases/
#
# * The next URI path-key (after "releases") will be the X.Y.Z release-number
# * The next URI path-key is the platform. Currently valid values are:
#   * linux-aarch64
#   * linux-x86_64
#   * mac
#   * win32
#   * win64-aarch64
#   * win64
# * The next URI path-key is the language/localization.
# * The final URI path-key is the file-name of the installation-archive
#
# Note: While MSI installers are available for Windows, this formula has not
#       been tested with them due to the ability to directly traverse HTTP
#       hierarchies not being readily available

firefox:
  lookup:
    installer_uri_win: 'https://download-installer.cdn.mozilla.net/pub/firefox/releases/147.0.4/win64/en-US/Firefox%20Setup%20147.0.4.exe'
    installer_uri_elx: (NOT YET IMPLEMENTED)
